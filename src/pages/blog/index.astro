---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description="Writing on AI/ML, engineering, and technology." />
  </head>
  <body>
    <Header />
    <main>
      <h1>Blog</h1>
      {posts.length === 0 ? (
        <p class="empty">No posts yet. Check back soon.</p>
      ) : (
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>
                {post.data.heroImage && (
                  <img width={720} height={360} src={post.data.heroImage} alt="" />
                )}
                <h4 class="title">{post.data.title}</h4>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
                {post.data.description && <p class="description">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 720px;
  }
  h1 {
    margin-bottom: 1.5em;
  }
  .empty {
    color: rgb(var(--gray));
    font-style: italic;
  }
  ul {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }
  ul li a {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  ul li a:hover .title {
    color: var(--accent);
  }
  .title {
    margin: 0.25em 0 0.1em;
    color: rgb(var(--black));
    font-size: 1.25rem;
  }
  .date {
    margin: 0;
    color: rgb(var(--gray));
    font-size: 0.875rem;
  }
  .description {
    margin: 0.25em 0 0;
    font-size: 0.9rem;
    color: rgb(var(--gray-dark));
  }
  img {
    border-radius: 8px;
    width: 100%;
    height: auto;
    margin-bottom: 0.5em;
  }
</style>

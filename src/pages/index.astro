---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SOCIAL } from '../consts';

const articles = [
  {
    title: "Presenting Precog, Nubank's Real Time Event AI",
    description: "Understand the promising future of Precog and customer representation AI at Nubank.",
    url: "https://building.nubank.com.br/presenting-precog-nubanks-real-time-event-ai/",
    publication: "Building Nubank",
  },
  {
    title: "Implementing Liveness Detection with Google ML Kit",
    description: "Liveness detection is the ability to differentiate between a live person and a static image, given a set of photos.",
    url: "https://towardsdatascience.com/implementing-liveness-detection-with-google-ml-kit-5e8c9f6dba45",
    publication: "Towards Data Science",
  },
  {
    title: "Want a Career in Machine Learning? Here's What You Need to Know.",
    description: "There are many paths to a career in machine learning. How do you know which one to take?",
    url: "https://builtin.com/machine-learning/machine-learning-careers",
    publication: "Built In",
  },
  {
    title: "Carreiras em Machine Learning: o Presente e o Futuro",
    description: "Uma análise das carreiras em Machine Learning hoje e para onde estão indo. [pt-BR]",
    url: "http://horizontes.sbc.org.br/index.php/2020/07/26/carreiras-em-machine-learning/",
    publication: "Revista SBC Horizontes",
  },
  {
    title: "2020: The Year of Reality in AI",
    description: "Artificial Intelligence, Machine Learning, Deep Learning, Neural Networks. In the past few years, these technical terms have become unavoidable buzzwords.",
    url: "https://www.linkedin.com/pulse/2020-year-reality-ai-cristiano-breuel/",
    publication: "LinkedIn",
  },
  {
    title: "ML Ops: Machine Learning as an Engineering Discipline",
    description: "As ML matures from research to applied business solutions, so do we need to improve the maturity of its operation processes.",
    url: "https://towardsdatascience.com/ml-ops-machine-learning-as-an-engineering-discipline-b86ca4874a3f",
    publication: "Towards Data Science",
  },
  {
    title: "Itaú Unibanco: How we built a CI/CD Pipeline for machine learning with online training in Kubeflow",
    description: "How Itaú Unibanco built a digital customer service tool using NLP and machine learning, with a full CI/CD pipeline on Kubeflow.",
    url: "https://cloud.google.com/blog/products/ai-machine-learning/itau-unibanco-how-we-built-a-cicd-pipeline-for-machine-learning-with-online-training-in-kubeflow",
    publication: "Google Cloud Blog",
  },
  {
    title: "How To Control Access To BigQuery At Row Level With Groups",
    description: "A guide to implementing fine-grained row-level access control in BigQuery using groups.",
    url: "https://medium.com/google-cloud/how-to-control-access-to-bigquery-at-row-level-with-groups-1cbccb111d9e",
    publication: "Google Cloud — Medium",
  },
];

const talks = [
  {
    title: "MLOps Meetup #18 — Running a Fintech on ML",
    event: "MLOps.community Meetup",
    date: "June 2020",
    url: "https://www.youtube.com/watch?v=ry_P5D_d7XA",
    lang: "en",
  },
  {
    title: "O que é MLOps? | Nubank Machine Learning Meetup",
    event: "Nubank ML Meetup",
    date: "2020",
    url: "https://www.youtube.com/watch?v=Z42UL_4AQvI",
    lang: "pt-BR",
  },
  {
    title: "Painel: MLOps no Nubank, Wildlife e BCG",
    event: "Nubank ML Meetup",
    date: "2020",
    url: "https://www.youtube.com/watch?v=kJ_FLNUK6P0",
    lang: "pt-BR",
  },
  {
    title: "O que é MLOps?",
    event: "Datafest Campinas",
    date: "December 2019",
    url: "https://www.youtube.com/watch?v=2dJYV06NC-Y",
    lang: "pt-BR",
  },
  {
    title: "Machine Learning e o MLOps — Hipsters #171",
    event: "Hipsters Ponto Tech Podcast",
    date: "2020",
    url: "https://hipsters.tech/machine-learning-e-o-mlops-hipsters-171/",
    lang: "pt-BR",
  },
  {
    title: "IBM 2011 Brazilian Software Lab TechDay",
    event: "IBM TechDay",
    date: "2011",
    url: "https://www.slideshare.net/ThadeuRusso/scala-clojure-techday2011",
    lang: "en",
  },
];

const academic = [
  {
    title: "Join point selectors",
    venue: "SPLAT '07: Proceedings of the 5th workshop on Software engineering properties of languages and aspect technologies",
    details: "March 2007, Pages 3–es",
    url: "https://dl.acm.org/doi/abs/10.1145/1233843.1233846",
    doi: "https://doi.org/10.1145/1233843.1233846",
  },
  {
    title: "User-Defined Join Point Selectors — An Extension Mechanism for Pointcut Languages",
    venue: "Journal of Object Technology",
    details: "vol. 7, no. 9, Special Issue: SPLAT, December 2008, pages 5–24",
    url: "http://www.jot.fm/issues/issue_2008_12/article1/",
    doi: "http://dx.doi.org/10.5381/jot.2008.7.9.a1",
  },
  {
    title: "Seletores de pontos de junção: um mecanismo de extensão para linguagens e arcabouços orientados a aspectos",
    venue: "Master's Dissertation — Instituto de Matemática e Estatística, Universidade de São Paulo",
    details: "2008",
    url: "https://teses.usp.br/teses/disponiveis/45/45134/tde-10062008-160304/",
    doi: "https://doi.org/10.11606/D.45.2008.tde-10062008-160304",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>

      <!-- Hero -->
      <section class="hero">
        <div class="hero-text">
          <h1>Cristiano Breuel</h1>
          <p class="tagline">AI/ML Engineer &amp; Technical Leader</p>
          <div class="hero-social">
            <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href={SOCIAL.mastodon} target="_blank" rel="noopener noreferrer me">Mastodon</a>
            <a href={SOCIAL.medium} target="_blank" rel="noopener noreferrer">Medium</a>
            <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </div>
      </section>

      <div class="divider"></div>

      <!-- Articles -->
      <section id="articles">
        <h2>Articles</h2>
        <div class="article-grid">
          {articles.map((a) => (
            <a href={a.url} class="article-card" target="_blank" rel="noopener noreferrer">
              <span class="publication">{a.publication}</span>
              <h3>{a.title}</h3>
              <p>{a.description}</p>
            </a>
          ))}
        </div>
      </section>

      <div class="divider"></div>

      <!-- Talks -->
      <section id="talks">
        <h2>Talks &amp; Interviews</h2>
        <ul class="talk-list">
          {talks.map((t) => (
            <li class="talk-item">
              <a href={t.url} target="_blank" rel="noopener noreferrer">{t.title}</a>
              <span class="talk-meta">
                {t.event} &mdash; {t.date}
                {t.lang !== 'en' && <span class="lang-badge">{t.lang}</span>}
              </span>
            </li>
          ))}
        </ul>
      </section>

      <div class="divider"></div>

      <!-- Projects -->
      <section id="projects">
        <h2>Projects</h2>
        <div class="project-card">
          <h3>Vogon</h3>
          <p>
            A tool for scalable customization of video campaigns at Google, enabling personalized
            video ads at scale on YouTube.
          </p>
          <div class="project-links">
            <a href="https://github.com/google/vogon" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="https://www.thinkwithgoogle.com/intl/en-apac/ad-channel/video/creating-dynamic-personalized-video-ads-vogon/" target="_blank" rel="noopener noreferrer">Think with Google</a>
          </div>
        </div>
      </section>

      <div class="divider"></div>

      <!-- Academic -->
      <section id="academic">
        <h2>Academic</h2>
        <ul class="academic-list">
          {academic.map((p) => (
            <li class="academic-item">
              <a href={p.url} target="_blank" rel="noopener noreferrer"><strong>{p.title}</strong></a>
              <span class="academic-meta">{p.venue}</span>
              <span class="academic-details">{p.details} &mdash; <a href={p.doi} target="_blank" rel="noopener noreferrer">{p.doi}</a></span>
            </li>
          ))}
        </ul>
      </section>

      <div class="divider"></div>

      <!-- Patents -->
      <section id="patents">
        <h2>Patents</h2>
        <ul class="academic-list">
          <li class="academic-item">
            <a href="https://portal.unifiedpatents.com/patents/patent/US-20150170060-A1" target="_blank" rel="noopener noreferrer">
              <strong>US-20150170060-A1 — Force-based Assignments</strong>
            </a>
            <p class="patent-abstract">
              A method for assigning locations to persons in a group using force-directed graph
              algorithms derived from communication patterns between group members.
            </p>
          </li>
        </ul>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: 1000px;
    max-width: calc(100% - 2em);
    margin: 0 auto;
    padding: 0 1em 4em;
  }

  /* Hero */
  .hero {
    padding: 4em 0 3em;
  }
  .hero h1 {
    font-size: 3rem;
    margin-bottom: 0.2em;
    color: rgb(var(--black));
  }
  .tagline {
    font-size: 1.2rem;
    color: rgb(var(--gray));
    margin: 0 0 1.5em;
    font-weight: 400;
    letter-spacing: 0.01em;
  }
  .hero-social {
    display: flex;
    gap: 1.25em;
    flex-wrap: wrap;
  }
  .hero-social a {
    color: var(--accent);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }
  .hero-social a:hover {
    border-bottom-color: var(--accent);
  }

  /* Section divider */
  .divider {
    border-top: 1px solid rgb(var(--gray-light));
    margin: 2em 0;
  }

  /* Section headings */
  section h2 {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(var(--gray));
    font-weight: 700;
    margin-bottom: 1.5em;
  }

  /* Articles grid */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25em;
  }
  .article-card {
    display: flex;
    flex-direction: column;
    gap: 0.4em;
    padding: 1.25em;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, border-color 0.2s;
    background: white;
  }
  .article-card:hover {
    box-shadow: var(--box-shadow);
    border-color: rgb(var(--gray));
  }
  .publication {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    font-weight: 700;
  }
  .article-card h3 {
    font-size: 1rem;
    line-height: 1.4;
    color: rgb(var(--black));
    margin: 0;
  }
  .article-card p {
    font-size: 0.875rem;
    color: rgb(var(--gray));
    line-height: 1.5;
    margin: 0;
  }

  /* Talks */
  .talk-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25em;
  }
  .talk-item {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
  }
  .talk-item a {
    font-size: 1rem;
    font-weight: 600;
    color: rgb(var(--black));
    text-decoration: none;
  }
  .talk-item a:hover {
    color: var(--accent);
  }
  .talk-meta {
    font-size: 0.85rem;
    color: rgb(var(--gray));
    display: flex;
    align-items: center;
    gap: 0.5em;
  }
  .lang-badge {
    font-size: 0.7rem;
    background: rgb(var(--gray-light));
    color: rgb(var(--gray-dark));
    padding: 1px 6px;
    border-radius: 4px;
    font-weight: 600;
  }

  /* Projects */
  .project-card {
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
    padding: 1.5em;
    background: white;
    max-width: 480px;
  }
  .project-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5em;
    color: rgb(var(--black));
  }
  .project-card p {
    font-size: 0.9rem;
    color: rgb(var(--gray-dark));
    margin: 0 0 1em;
    line-height: 1.6;
  }
  .project-links {
    display: flex;
    gap: 1em;
  }
  .project-links a {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .project-links a:hover {
    text-decoration: underline;
  }

  /* Academic & Patents */
  .academic-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75em;
  }
  .academic-item {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
  }
  .academic-item a {
    text-decoration: none;
    color: rgb(var(--black));
  }
  .academic-item a:hover {
    color: var(--accent);
  }
  .academic-item strong {
    font-size: 1rem;
  }
  .academic-meta {
    font-size: 0.85rem;
    color: rgb(var(--gray-dark));
    font-style: italic;
  }
  .academic-details {
    font-size: 0.82rem;
    color: rgb(var(--gray));
  }
  .academic-details a {
    font-size: inherit;
    color: rgb(var(--gray));
    word-break: break-all;
  }
  .patent-abstract {
    font-size: 0.875rem;
    color: rgb(var(--gray-dark));
    line-height: 1.6;
    margin: 0.4em 0 0;
  }

  @media (max-width: 720px) {
    .hero h1 {
      font-size: 2.2rem;
    }
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
